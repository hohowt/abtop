#!/usr/bin/env bash
set -eo pipefail

BASE_DIR="${HOME}/.abtop"
BIN_DIR="${BASE_DIR}/bin"
BIN_PATH="${BIN_DIR}/abtop"

REPO="graykode/abtop"

main() {
  need_cmd curl
  need_cmd tar
  need_cmd uname

  say "installing abtop"

  detect_platform
  ensure_dir
  download
  add_to_path

  say ""
  say "abtop installed to ${BIN_PATH}"
  say ""
  say "run 'abtop' to get started"
}

detect_platform() {
  OS=$(uname -s)
  ARCH=$(uname -m)

  case "$OS" in
    Darwin) OS="apple-darwin" ;;
    Linux)  OS="unknown-linux-gnu" ;;
    *)      err "unsupported OS: $OS" ;;
  esac

  case "$ARCH" in
    x86_64)  ARCH="x86_64" ;;
    aarch64|arm64) ARCH="aarch64" ;;
    *)       err "unsupported architecture: $ARCH" ;;
  esac

  TARGET="${ARCH}-${OS}"
  say "detected platform: ${TARGET}"
}

ensure_dir() {
  mkdir -p "$BIN_DIR"
}

download() {
  # Get latest release tag
  LATEST=$(curl -sS "https://api.github.com/repos/${REPO}/releases/latest" | grep '"tag_name"' | cut -d '"' -f 4)

  if [ -z "$LATEST" ]; then
    err "could not determine latest release"
  fi

  say "downloading abtop ${LATEST} ..."

  URL="https://github.com/${REPO}/releases/download/${LATEST}/abtop-${TARGET}.tar.gz"

  curl -sSfL "$URL" -o "/tmp/abtop-${TARGET}.tar.gz" || err "download failed — check https://github.com/${REPO}/releases"
  tar xzf "/tmp/abtop-${TARGET}.tar.gz" -C "$BIN_DIR"
  chmod +x "$BIN_PATH"
  rm -f "/tmp/abtop-${TARGET}.tar.gz"

  say "installed abtop ${LATEST}"
}

add_to_path() {
  SHELL_NAME=$(basename "$SHELL")
  EXPORT_LINE="export PATH=\"${BIN_DIR}:\$PATH\""

  case "$SHELL_NAME" in
    bash)
      PROFILE="${HOME}/.bashrc"
      ;;
    zsh)
      PROFILE="${HOME}/.zshrc"
      ;;
    fish)
      EXPORT_LINE="fish_add_path ${BIN_DIR}"
      PROFILE="${HOME}/.config/fish/config.fish"
      ;;
    *)
      say "could not detect shell profile — manually add ${BIN_DIR} to your PATH"
      return
      ;;
  esac

  if [ -f "$PROFILE" ] && grep -q "${BIN_DIR}" "$PROFILE" 2>/dev/null; then
    return
  fi

  echo "$EXPORT_LINE" >> "$PROFILE"
  say "added ${BIN_DIR} to PATH in ${PROFILE}"
  say "run 'source ${PROFILE}' or open a new terminal to use abtop"
}

say() {
  echo "abtopup: $1"
}

err() {
  say "error: $1" >&2
  exit 1
}

need_cmd() {
  if ! command -v "$1" > /dev/null 2>&1; then
    err "need '$1' (command not found)"
  fi
}

main
